# Application
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# CORS — comma-separated list of allowed origins (leave empty to allow all, dev only)
CORS_ORIGIN=

# Database
DATABASE_URL=postgresql://wackraces:wackraces@db:5432/wackraces
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Redis
REDIS_URL=redis://redis:6379

# JWT — must be changed to strong random secrets in production (min 32 chars)
JWT_SECRET=change-me-in-production-32-chars-minimum
JWT_REFRESH_SECRET=change-me-refresh-in-production-32-chars

# S3 / Object Storage
S3_BUCKET=wackraces-media
S3_REGION=us-east-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Frontend (web/)
# Default event ID shown on the live map (optional — set to a real event UUID after creation)
VITE_DEFAULT_EVENT_ID=
